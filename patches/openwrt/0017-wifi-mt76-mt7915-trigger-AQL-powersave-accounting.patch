Subject: wifi: mt76: mt7915: trigger AQL powersave accounting

diff --git a/package/kernel/mt76/patches/805-wifi-mt76-mt7915-trigger-AQL-powersave-accounting.patch b/package/kernel/mt76/patches/805-wifi-mt76-mt7915-trigger-AQL-powersave-accounting.patch
new file mode 100644
index 0000000000000000000000000000000000000000..8f9907ac11c7ea3eca9c253316e4a22beb72e877
--- /dev/null
+++ b/package/kernel/mt76/patches/805-wifi-mt76-mt7915-trigger-AQL-powersave-accounting.patch
@@ -0,0 +1,24 @@
+From 3f7d43de3b660dad087842cd063c9639891931ef Mon Sep 17 00:00:00 2001
+From: David Bauer <mail@david-bauer.net>
+Date: Fri, 30 Jan 2026 17:07:53 +0100
+Subject: [PATCH] wifi: mt76: mt7915: trigger AQL powersave accounting
+
+---
+ mt7915/mcu.c | 1 +
+ 1 file changed, 1 insertion(+)
+
+diff --git a/mt7915/mcu.c b/mt7915/mcu.c
+index ba786223..c502e8be 100644
+--- a/mt7915/mcu.c
++++ b/mt7915/mcu.c
+@@ -422,6 +422,7 @@ static void mt7915_mcu_rx_ps_sync(struct mt7915_dev *dev, struct sk_buff *skb)
+ 	if (!sta)
+ 		return;
+ 
++	ieee80211_sta_aql_ps(sta, !!p->ps_bit);
+ 	if (p->ps_bit) {
+ 		set_bit(MT_WCID_FLAG_PS, &wcid->flags);
+ 		wcid->ps_entered_time = jiffies;
+-- 
